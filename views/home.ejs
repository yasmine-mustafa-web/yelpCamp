<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&family=Fredoka:wght@300..700&family=Marmelad&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Outfit:wght@100..900&family=Playwrite+IE:wght@100..400&family=Poiret+One&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Quicksand:wght@300..700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/home.css">
    <title>YelpCamp</title>
</head>
<body class="d-flex text-center text-white bg-dark">
    <div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
        <header class="mb-auto">
            <div class="navbar">
                <h3 class="float-md-left mb-0">YelpCamp</h3>
                <nav class="nav nav-masthead justify-content-center float-md-right">    
                    <a href="/" class="nav-link active">Home</a>
                    <a href="/campgrounds" class="nav-link">Campgrounds</a>
                    <%if(!currentUser){%>
                    <a href="/login" class="btn bg-dark px-1 py-1 nav-link">Login</a>
                    <a href="/register" class="btn nav-link bg-dark  px-1 py-1">Register</a>
                    <% }else{ %>
                    <a href="/logout" class="btn nav-link bg-dark  px-1 py-1">Logout</a>
                        <% } %>
                </nav>
            </div>
        </header>
        <main class="px-3">
            <h1 class="text-white" style="font-family: 'Cinzel' , serif;">YelpCamp</h1>
            <p class="lead text-white">Welcome to YelpCamp! </p><p> Jump right in and explore our campgrounds</p> <p class="par"> Feel free to share some of your own and comments on others! </p>
            <a href="/campgrounds" class="btn btn-lg btn-secondary font-weight-bold">View Campgrounds</a>
        </main>
        <footer class="mt-auto text-white-50">
            <p>&copy; 2026 YelpCamp</p>
        </footer>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  <script src="/javascripts/validatedForm.js"></script>
</body>
</html>